<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script> 
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 mb-5" href="/logout">Logout</a>
        </div>
        <h5 class="mb-5">You can Edit a post.</h5>
        <form method="post" action="/update/<%=post._id%>">
            <textarea placeholder="What's on your mind?" class="block p-3 outline-none w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md" name="content"><%= post.content%></textarea>
            <input class="text-black mt-2 w-40 px-3 py-2 bg-yellow-500 rounded-md block"type="submit" value="Update Post">
        </form>
    </div>
</body>
</html>